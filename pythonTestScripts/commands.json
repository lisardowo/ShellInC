{
    "stage1": {
        "commands" : ["echo hello",
                     "echo hello world",
                     "type echo",
                     "type ls",
                     "invalid_command_xyz",
                     "exit 0"
                    ],
        "expectedOut" : ["hello",
                         "hello world",
                         "echo is a shell builtin",
                         "ls is usr/bin/ls",
                         "invalid_command_xyz: command not found",
                         "No output, shell should exit cleanly"
                         
                        ]

    },
    "stage2": {
        "commands" : ["pwd",
                     "cd NONEXISTENTDIR",
                     "pwd",
                     "cd ",
                     "pwd"
                    ],
        "expectedOut" : ["/home/<YOURUSER>/<PATH>/src",
                         "cd: NONEXISTENTDIR: No such file or directory",
                         "/home/<YOURUSER>/PATH/src",
                         "No output, shall change to HOME",
                         "/home/<YOURUSER>/"
                        ]
    },
    "stage3": {
        "commands" : ["echo 'hello world'",
                     "echo \"hello world\" ",
                     "echo one\two",
                     "echo \"a\"b\"",
                     "echo 'a\b'",
                     "\"echo\" \"quoted executable\""
                    ],
        "expectedOut" : ["hello world",
                         "hello world",
                         "onetwo",
                         "ab",
                         "a\b",
                         "quoted executable"
                        ]
    },
    "stage4": {
        "commands" : ["echo hello world > out.txt",
                     "cat out.txt",
                     "ls /non-existent 2> err.txt",
                     "cat err.txt",
                     "echo linea1 >> out.txt",
                     "cat out.txt"
                    ],
        "expectedOut" : ["No output, shall create a file called out.txt",
                         "hello world",
                         "No output, shall create a file called err.txt",
                         "ls: cannot access '/non-existent': No such file or directory",
                         "invalid_command_xyz: command not found",
                         "hello world \n linea1"
                        ]
    },
    "stage5": {
        "commands" : ["ty+TAB",
                     "ech+TAB",
                     "mkdi+TAB"
                    ],
        "expectedOut" : ["self complete to type",
                         "self complete to echo",
                         "self complete to mkdir"
                        ]
    },
    "stage6": {
        "commands" : ["cat te+TAB",
                     "cat src/ma+TAB",
                     "cd sr+TAB",
                     "cat src/test/te+TAB",
                     "cat src/no+TAB",
                     "cat ./s+TAB"
                    ],
        "expectedOut" : ["hello",
                         "hello world",
                         "echo is a shell builtin",
                         "usr/bin/ls",
                         "invalid_command_xyz: command not found",
                         "No output, shell should exit cleanly"
                        ]
    },
    "stage7": {
        "commands" : ["sleep 1 &",
                     "jobs",
                     "sleep 2 &",
                     "jobs",
                     "sleep 1",
                     "jobs"
                    ],
        "expectedOut" : ["hello",
                         "hello world",
                         "echo is a shell builtin",
                         "usr/bin/ls",
                         "invalid_command_xyz: command not found",
                         "No output, shell should exit cleanly"
                        ]
    },
    "stage8": {
        "commands" : ["echo hello | cat",
                     "printf \"a\nb\n\" | wc -l",
                     "echo echo | re a-z A-Z",
                     "printf \"x\ny\nz\n\" | grep y",
                     "echo test | rev",
                     "printf \"1\n2\n3\n\" | tail -n 1"
                    ],
        "expectedOut" : ["hello",
                         "hello world",
                         "echo is a shell builtin",
                         "usr/bin/ls",
                         "invalid_command_xyz: command not found",
                         "No output, shell should exit cleanly"
                        ]
    },
    "stage9": {
        "commands" : ["echo cmd1",
                     "echo cmd2",
                     "history"
                    ],
        "expectedOut" : ["cmd1",
                         "cmd2",
                         "most recent shall be: echo cmd1, echo cmd2"
                        ]
    },
    "stage10": {
        "commands" : {"session1":  ["echo persist1",
                     "echo persist2",
                     "history",
                     "exit"
                    ],
                    "session2" : ["history",
                     "echo persist3",
                     "history",
                     "exit"
                    ]
                },
        "expectedOut" : {"session1":  ["persist1",
                     "persist2",
                     "most recent commands shall be persist1, persist2",
                     "no output, shall exit cleanly"
                    ],
                    "session2" : ["most recent commands shall be: history, exit, persist1, persist2",
                     "echo persist3",
                     "history most recent command shall be persist3",
                     "exit"
                    ]
                }
    }
}